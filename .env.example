# ── OpenAI 
OPENAI_API_KEY=

# ── Supabase 
# Encontre em: dashboard.supabase.com → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# service_role key (NÃO a anon key!)

# ── Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# ── Configurações opcionais ──────────────────────────────────
EMBEDDING_BACKEND=openai       # "openai" ou "huggingface"
EMBEDDING_DIMENSIONS=1536      # 1536 para OpenAI, 768 para E5
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

RETRIEVAL_K_SEMANTIC=20
RETRIEVAL_K_BM25=20
RETRIEVAL_K_FINAL=5
RERANKER_MODEL=BAAI/bge-reranker-base


