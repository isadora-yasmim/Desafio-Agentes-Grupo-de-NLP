# ── OpenAI 
OPENAI_API_KEY=

# ── OpenAI (OBRIGATÓRIO) ──────────────────────────────────────────────────
# Insira a sua chave da OpenAI aqui (necessário para o LLM e Embeddings)
OPENAI_API_KEY=sk-...

# ── Qdrant (Banco Vetorial Local via Docker) ────────────────
# NÃO ALTERAR: Esta é a rota interna do Docker Compose
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ── Configurações de RAG ───────────────
EMBEDDING_BACKEND=openai       
EMBEDDING_DIMENSIONS=1536      
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

RETRIEVAL_K_SEMANTIC=20
RETRIEVAL_K_BM25=20
RETRIEVAL_K_FINAL=5
RERANKER_MODEL=BAAI/bge-reranker-base


